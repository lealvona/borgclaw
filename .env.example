# BorgClaw Deployment Configuration
# Copy to .env and fill in your values

# LLM Provider API Keys (choose one or configure in config.toml)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# KIMI_API_KEY=...
# MINIMAX_API_KEY=...
# Z_API_KEY=...

# Telegram Bot Token (if using Telegram channel)
# TELEGRAM_BOT_TOKEN=...

# Webhook Secret (if using webhook channel)
# WEBHOOK_SECRET=...

# Database encryption key (generate with: openssl rand -base64 32)
# BORGCLAW_ENCRYPTION_KEY=...
